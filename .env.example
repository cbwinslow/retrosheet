PGHOST=localhost
PGPORT=5432
PGDATABASE=retrosheet
PGUSER=postgres
PGPASSWORD=

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=

GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=

CODEX_PROVIDER=openai

# ============================================
# Docker Deployment Configuration
# ============================================

# Domain Configuration
APP_DOMAIN=cloudcurio.cc
TRAEFIK_DOMAIN=traefik.cloudcurio.cc

# Let's Encrypt (required for HTTPS)
ACME_EMAIL=admin@cloudcurio.cc

# Database (Docker uses these, local dev uses PG* above)
POSTGRES_USER=baseball
POSTGRES_PASSWORD=changeme-strong-password-here
POSTGRES_DB=retrosheet

# Live Server Configuration
LIVE_POLL_INTERVAL=10
LIVE_SERVER_HOST=0.0.0.0
LIVE_SERVER_PORT=8000

# Traefik Logging
TRAEFIK_LOG_LEVEL=INFO

# Grafana (optional - for monitoring profile)
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# Application Logging
LOG_LEVEL=INFO
